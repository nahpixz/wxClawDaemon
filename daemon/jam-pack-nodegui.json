{
  "fetch": {
    "gitUrl": "file://D:/Documents/_Project/wxclaw_daemon",
    "postFetch": [
      "powershell -Command \"Move-Item -Path git_source/daemon/* -Destination git_source/ -Force\""
    ],
    "gitFromCwd": true
  },
  "build": {
    "packageManager": "npm"
  },
  "prune": {
    "skip": false,
    "patterns": [
      {
        "keep": [
          "package.json",
          "dist/*.js",
          "dist/assets/*",
          "cloudflared.yaml"
        ]
      }
    ]
  },
  "addLauncher": {
    "jsEntryPoint": "dist/main.js",
    "windowsIcon": "assets/icon.ico"
  },
  "quietQode": {},
  "zip": {
    "platforms": ["linux", "macos", "windows"],
    "skip": true
  },
  "nsis": {
    "skip": false,
    "description": "wxclawDaemon",
    "detailColors": "3db54a 000000",
    "appTitle": "wxclawDaemon",
    "installerIcon": "$pruneStep_trashDirectory/assets/icon.ico",
    "uninstallerIcon": "$pruneStep_trashDirectory/assets/icon.ico"
  }
}
